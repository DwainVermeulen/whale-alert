# Telegram
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# APIs
ETHERSCAN_API_KEY=your_etherscan_api_key
SOLANA_RPC=https://api.mainnet-beta.solana.com

# Stripe (Get these from Stripe Dashboard)
# https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxx

# Create products in Stripe Dashboard, then get price IDs
# https://dashboard.stripe.com/test/products
STRIPE_PRO_PRICE_ID=price_xxxxxxxxxxxx
STRIPE_ENTERPRISE_PRICE_ID=price_xxxxxxxxxxxx

# Webhook secret (after creating webhook in Stripe Dashboard)
# https://dashboard.stripe.com/test/webhooks
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxx

# JWT Secret (change this!)
JWT_SECRET=change-this-to-a-secure-random-string

# Email (SMTP) - Optional, for email notifications
# Use Gmail, SendGrid, Mailgun, etc.
# Gmail example (with App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="Whale Alert" <noreply@yourdomain.com>
